---
/**
 * Componente Modal para filtrar subastas
 */
import provinces from '../data/provinces.json';
import auctionTypes from '../data/auctionTypes.json';
---

<div id="filter-modal" class="modal-overlay hidden">
  <div class="modal-content card">
    <header class="modal-header">
      <h2>Filtrar Subastas</h2>
      <button id="close-modal-btn" class="close-btn">&times;</button>
    </header>

    <form id="filter-form" class="filter-form">
      <div class="form-grid">
        <!-- IDs de Subasta -->
        <div class="form-group full-width">
          <label for="auctionIds">IDs de Subasta (separados por coma)</label>
          <input type="text" id="auctionIds" name="auctionIds" placeholder="ej: 12345, 67890" />
        </div>

        <!-- Tipo de Subasta -->
        <div class="form-group">
          <label for="type">Tipo de Subasta</label>
          <select id="type" name="type">
            <option value="">Cualquier tipo</option>
            {auctionTypes.map(type => (
              <option value={type}>{type}</option>
            ))}
          </select>
        </div>

        <!-- Fecha Fin -->
        <div class="form-group">
          <label for="dateOfEnd">Fecha de Fin (hasta)</label>
          <input type="date" id="dateOfEnd" name="dateOfEnd" />
        </div>

        <!-- Provincia -->
        <div class="form-group full-width">
          <label>Provincias (Selecciona varias)</label>
          <div class="checkbox-group" id="province-checks">
            {provinces.map(province => (
              <label class="checkbox-item">
                <input type="checkbox" name="provinces" value={province} />
                <span>{province}</span>
              </label>
            ))}
          </div>
        </div>

        <!-- Estado -->
        <div class="form-group">
          <label for="status">Estado</label>
          <select id="status" name="status">
            <option value="">Cualquier estado</option>
            <option value="ACTIVE" selected>En curso</option>
            <option value="UPCOMING">Próximamente</option>
            <option value="EXPIRED">Finalizada</option>
          </select>
        </div>

        <!-- Multilote -->
        <div class="form-group">
          <label for="isMultiLot">Multilote</label>
          <select id="isMultiLot" name="isMultiLot">
            <option value="">Indiferente</option>
            <option value="false">No</option>
            <option value="true">Sí</option>
          </select>
        </div>

        <!-- Con Pujas -->
        <div class="form-group">
          <label for="hasBids">¿Tiene Pujas?</label>
          <select id="hasBids" name="hasBids">
            <option value="">Indiferente</option>
            <option value="true">Sí</option>
            <option value="false">No</option>
          </select>
        </div>
      </div>

      <footer class="modal-footer">
        <button type="button" id="clear-filters-btn" class="btn-secondary">Limpiar</button>
        <div class="actions">
          <button type="button" id="cancel-modal-btn" class="btn-ghost">Cancelar</button>
          <button type="submit" class="btn-accent">Aplicar Filtros</button>
        </div>
      </footer>
    </form>
  </div>
</div>

<script>
  const modal = document.getElementById('filter-modal');
  const closeBtn = document.getElementById('close-modal-btn');
  const cancelBtn = document.getElementById('cancel-modal-btn');
  const clearBtn = document.getElementById('clear-filters-btn');
  const form = document.getElementById('filter-form') as HTMLFormElement;

  // Funciones de apertura/cierre
  const openModal = () => modal?.classList.remove('hidden');
  const closeModal = () => modal?.classList.add('hidden');

  // Eventos de cierre
  closeBtn?.addEventListener('click', closeModal);
  cancelBtn?.addEventListener('click', closeModal);
  
  // Cerrar al hacer clic fuera del contenido
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Limpiar formulario
  clearBtn?.addEventListener('click', () => {
    form?.reset();
  });

  // Escuchar evento personalizado para abrir el modal desde otros componentes
  document.addEventListener('filter:open', openModal);

  // Evitar que el formulario recargue la página y redirigir con filtros
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const params = new URLSearchParams();

    formData.forEach((value, key) => {
      // Solo añadir si el valor no está vacío
      if (value && value.toString().trim() !== '') {
        // Si ya existe la clave (caso de múltiples provincias), no hacemos nada aquí
        // URLSearchParams.append añade otra instancia de la clave, lo cual es correcto
        params.append(key, value.toString());
      }
    });

    // Redirigir a la página de resultados con los parámetros
    window.location.href = `/auctionsList?${params.toString()}`;
  });
</script>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    transition: opacity 0.3s ease;
  }

  .modal-content {
    width: 90%;
    max-width: 600px;
    background: var(--color-bg-card);
    padding: 2rem;
    position: relative;
    box-shadow: var(--shadow-xl);
    animation: modalAppear 0.3s ease-out;
  }

  @keyframes modalAppear {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  .modal-header h2 {
    margin: 0;
    font-size: 1.5rem;
    color: var(--color-primary);
  }

  .close-btn {
    font-size: 2rem;
    line-height: 1;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .close-btn:hover {
    color: var(--color-accent);
  }

  .filter-form .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group.full-width {
    grid-column: 1 / -1;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-main);
  }

  .form-group input, 
  .form-group select {
    padding: 0.75rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    background: var(--color-bg-page);
    font-family: inherit;
    font-size: 0.95rem;
    appearance: auto;
    -webkit-appearance: auto;
    box-sizing: border-box;
    width: 100%;
  }

  .form-group input[type="checkbox"] {
    width: auto;
  }

  .filter-form .form-grid {
    min-width: 0;
  }

  .modal-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  .modal-footer .actions {
    display: flex;
    gap: 1rem;
  }

  .btn-ghost {
    padding: 0.75rem 1.5rem;
    color: var(--color-text-muted);
    font-weight: 500;
    transition: color 0.2s;
  }

  .btn-ghost:hover {
    color: var(--color-primary);
  }

  .btn-secondary {
    padding: 0.6rem 1.2rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    background: var(--color-bg-page);
    color: var(--color-primary);
  }

  .checkbox-group {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.5rem;
    max-height: 200px;
    overflow-y: auto;
    padding: 0.75rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    background: var(--color-bg-page);
  }

  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    cursor: pointer;
    transition: color 0.2s;
    min-width: 0;
  }

  .checkbox-item:hover {
    color: var(--color-accent);
  }

  .checkbox-item input {
    width: auto !important;
    flex-shrink: 0;
    cursor: pointer;
  }

  .checkbox-item span {
    word-break: break-word;
  }

  .hidden {
    display: none;
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .filter-form .form-grid {
      grid-template-columns: 1fr;
    }
    .modal-content {
      width: 95%;
      max-height: 90vh;
      padding: 1.25rem;
      overflow-y: auto;
      box-sizing: border-box;
    }
    .modal-header {
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
    }
    .modal-header h2 {
      font-size: 1.25rem;
    }
    .checkbox-group {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      max-height: 150px;
      padding: 0.5rem;
    }
    .modal-footer {
      flex-direction: column;
      gap: 0.75rem;
    }
    .modal-footer .actions {
      width: 100%;
      justify-content: stretch;
    }
    .modal-footer .actions button {
      flex: 1;
    }
    .btn-secondary {
      width: 100%;
    }
    .form-group input,
    .form-group select {
      font-size: 16px;
    }
  }


</style>
