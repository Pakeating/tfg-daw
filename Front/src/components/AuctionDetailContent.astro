---
/**
 * Contenido detallado de la subasta
 * Renderiza todos los campos de información de una subasta específica.
 */
---

<div id="auction-detail-wrapper">
  <div id="loading-detail" class="loading-state">
    Obteniendo todos los detalles de la subasta...
  </div>

  <div id="auction-detail-content" class="hidden">
    <div class="detail-container">
      <div class="detail-main">
        <header class="detail-header">
          <div class="header-top">
            <span class="property-type"></span>
            <div class="status-badge" data-status=""></div>
          </div>
          <h1 class="property-address"></h1>
          <p class="location">
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <span class="location-text"></span>
          </p>
        </header>

        <section id="lots-section" class="detail-section hidden">
          <h2>Lotes (<span id="lots-count">0</span>)</h2>
          <div id="lots-container" class="lots-accordion">
            <!-- Los lotes se inyectarán aquí -->
          </div>
        </section>

        <section id="econ-section" class="detail-section">
          <h2>Información Económica</h2>
          <div class="highlight-grid">
            <div class="highlight-item">
              <span class="label">Valor de Subasta</span>
              <span class="value auction-value"></span>
            </div>
            <div class="highlight-item">
              <span class="label">Depósito Requerido (5%)</span>
              <span class="value deposit-amount"></span>
            </div>
            <div class="highlight-item">
              <span class="label">Tasación</span>
              <span class="value appraisal"></span>
            </div>
            <div class="highlight-item">
              <span class="label">Puja Mínima</span>
              <span class="value minimum-bid"></span>
            </div>
          </div>
          <div class="data-grid mt-4">
            <div class="data-item">
              <span class="label">Tramos entre pujas:</span>
              <span class="value bid-increments"></span>
            </div>
            <div class="data-item">
              <span class="label">Importe reclamado:</span>
              <span class="value claimed-amount"></span>
            </div>
          </div>
        </section>

        <section id="desc-section" class="detail-section">
          <h2>Descripción de los bienes</h2>
          <p class="value goods-description"></p>
        </section>

        <section id="loc-section" class="detail-section">
          <h2>Ubicación y Referencias</h2>
          <div class="data-grid">
            <div class="data-item">
              <span class="label">Referencia Catastral:</span>
              <span class="value cadastral-reference"></span>
            </div>
            <div class="data-item">
              <span class="label">Código Postal:</span>
              <span class="value postal-code"></span>
            </div>
            <div class="data-item">
              <span class="label">Provincia:</span>
              <span class="value province-text"></span>
            </div>
            <div class="data-item">
              <span class="label">Ciudad:</span>
              <span class="value city-text"></span>
            </div>
            <div class="data-item">
              <span class="label">CRU:</span>
              <span class="value cru-text"></span>
            </div>
            <div class="data-item">
              <span class="label">Datos Registrales:</span>
              <span class="value registry-data"></span>
            </div>
          </div>
        </section>

        <section class="detail-section">
          <h2>Información de la Autoridad</h2>
          <div class="data-grid">
            <div class="data-item">
              <span class="label">Código Autoridad:</span>
              <span class="value authority-code"></span>
            </div>
            <div class="data-item">
              <span class="label">Descripción:</span>
              <span class="value authority-description"></span>
            </div>
            <div class="data-item">
              <span class="label">Dirección:</span>
              <span class="value authority-address"></span>
            </div>
            <div class="data-item">
              <span class="label">Teléfono:</span>
              <span class="value authority-phone"></span>
            </div>
            <div class="data-item">
              <span class="label">Email:</span>
              <span class="value authority-email"></span>
            </div>
            <div class="data-item">
              <span class="label">Fax:</span>
              <span class="value authority-fax"></span>
            </div>
          </div>
        </section>

        <section class="detail-section">
          <h2>Detalles Legales y Estado</h2>
          <div class="data-grid">
            <div class="data-item">
              <span class="label">ID Subasta:</span>
              <span class="value auction-id"></span>
            </div>
            <div class="data-item">
              <span class="label">Nº de Expediente:</span>
              <span class="value expediente"></span>
            </div>
            <div class="data-item">
              <span class="label">Nombre del Juzgado:</span>
              <span class="value court-name"></span>
            </div>
            <div class="data-item">
              <span class="label">Anuncio BOE:</span>
              <span class="value boe-announcement"></span>
            </div>
            <div class="data-item">
              <span class="label">Fecha Inicio:</span>
              <span class="value date-start"></span>
            </div>
            <div class="data-item">
              <span class="label">Fecha Fin:</span>
              <span class="value date-end"></span>
            </div>
            <div class="data-item">
              <span class="label">Vivienda Habitual:</span>
              <span class="value is-habitual-residence"></span>
            </div>
            <div class="data-item">
              <span class="label">Visitable:</span>
              <span class="value is-visitable"></span>
            </div>
            <div class="data-item">
              <span class="label">Estado Posesión:</span>
              <span class="value possession-status"></span>
            </div>
            <div class="data-item">
              <span class="label">Tiene Pujas:</span>
              <span class="value has-bids"></span>
            </div>
          </div>
        </section>

        <section class="detail-section">
          <h2>Información del Acreedor</h2>
          <div class="data-grid">
            <div class="data-item">
              <span class="label">Nombre Acreedor:</span>
              <span class="value creditor-name"></span>
            </div>
            <div class="data-item">
              <span class="label">NIF Acreedor:</span>
              <span class="value creditor-nif"></span>
            </div>
            <div class="data-item">
              <span class="label">Dirección Acreedor:</span>
              <span class="value creditor-address"></span>
            </div>
          </div>
        </section>


        <section id="docs-section" class="detail-section hidden">
          <h2>Documentos Adjuntos</h2>
          <ul id="docs-list" class="docs-list">
            <!-- Las URLs de los documentos se inyectarán aquí -->
          </ul>
        </section>
      </div>

      <aside class="detail-sidebar">
        <div class="sidebar-info" style="border: 2px solid var(--color-accent); background-color: #f8fafc;">
          <h3 style="color: var(--color-accent); display: flex; align-items: center; gap: 0.5rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
            Resumen
          </h3>
          <div class="data-item-simple">
            <span class="label">Estado:</span>
            <span class="value detail-status"></span>
          </div>
          <div class="data-item-simple">
            <span class="label">Valor de Subasta:</span>
            <span class="value sidebar-auction-value"></span>
          </div>
          <div class="data-item-simple">
            <span class="label">Tiene Pujas:</span>
            <span class="value sidebar-has-bids"></span>
          </div>

          <div id="ai-docs-summary-section" class="hidden" style="margin-top: 1.5rem;">
            <h4 style="font-size: 0.95rem; margin-bottom: 0.75rem; color: var(--color-text-main);">Resumen Documentos</h4>
            <div id="ai-summaries-list" style="display: flex; flex-direction: column; gap: 0.75rem;">
               <!-- Los resúmenes se inyectarán aquí -->
            </div>
          </div>

          <p style="font-size: 0.70rem; color: var(--color-text-muted); margin-top: 1rem; text-align: left; font-style: italic; border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
            Resumen realizado con IA, compruebe usted mismo antes de tomar una decision
          </p>
        </div>
      </aside>
    </div>
  </div>

  <div id="not-found-detail" class="no-results hidden">
    <p>Lo sentimos, no pudimos encontrar los detalles de esta subasta.</p>
    <a href="/auctionsList" class="btn-accent" id="back-to-list-bottom">Volver al Listado</a>
  </div>
</div>

<script>
  const wrapper = document.getElementById("auction-detail-content");
  const loading = document.getElementById("loading-detail");
  const notFound = document.getElementById("not-found-detail");

  // Escuchar el evento cuando se obtienen los datos de la subasta
  document.addEventListener("auctions:fetched", (event) => {
    // @ts-ignore
    const { results } = event.detail;

    loading.classList.add("hidden");

    if (!results || results.length === 0) {
      notFound.classList.remove("hidden");
      wrapper.classList.add("hidden");
      return;
    }

    const auction = results[0];
    notFound.classList.add("hidden");
    wrapper.classList.remove("hidden");

    function markdownToHtml(md: string): string {
      let html = md
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/```([\s\S]*?)```/g, '<pre><code>$1</code></pre>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank">$1</a>')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\*([^*]+)\*/g, '<em>$1</em>')
        .replace(/^### (.+)$/gm, '<h4>$1</h4>')
        .replace(/^## (.+)$/gm, '<h3>$1</h3>')
        .replace(/^# (.+)$/gm, '<h2>$1</h2>');

      const tableRegex = /^\|(.+)\|\n\|[-| :]+\|\n((?:\|.+\|\n?)*)/gm;
      html = html.replace(tableRegex, (_, headerRow, bodyRows) => {
        const headers = headerRow.split('|').map((h: string) => h.trim()).filter(Boolean);
        const rows = bodyRows.trim().split('\n').map((r: string) =>
          '<tr>' + r.split('|').map((c: string) => c.trim()).filter(Boolean).map((c: string) => `<td style="border:1px solid #ddd;padding:0.4rem 0.6rem">${c}</td>`).join('') + '</tr>'
        ).join('');
        return `<div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:0.85rem;margin:0.5rem 0"><thead><tr>${headers.map((h: string) => `<th style="border:1px solid #ddd;padding:0.4rem 0.6rem;background:#f8fafc;font-weight:700;text-align:left">${h}</th>`).join('')}</tr></thead><tbody>${rows}</tbody></table></div>`;
      });

      const lines = html.split('\n');
      const result: string[] = [];
      let inList = false;
      for (let i = 0; i < lines.length; i++) {
        const line = lines[i];
        const listMatch = line.match(/^(\s*)[-*]\s+(.+)/);
        if (listMatch) {
          if (!inList) { result.push('<ul style="padding-left:1.2rem;margin:0.25rem 0;list-style:disc">'); inList = true; }
          result.push(`<li style="margin:0;word-break:break-word">${listMatch[2]}</li>`);
        } else {
          if (inList) { result.push('</ul>'); inList = false; }
          if (line.trim()) result.push(`<p style="margin:0.25rem 0;word-break:break-word">${line.trim()}</p>`);
        }
      }
      if (inList) result.push('</ul>');
      return result.join('\n');
    }

    const setT = (selector: string, value: string) => {
      if (!wrapper) return;
      const el = wrapper.querySelector(selector);
      if (el) el.textContent = value || "No disponible";
    };

    // rellenar header
    const badge = wrapper.querySelector(".status-badge") as HTMLElement;
    if (badge) {
      badge.textContent = auction.status;
      badge.dataset.status = auction.status;
    }

    // Determinar si es multilote
    const isMultiLot = auction.lots && auction.lots.length > 1;
    
    if (isMultiLot) {
      setT(".property-type", "Multilote");
      setT(".property-address", "Subasta Multilote");
      setT(".location-text", "No disponible");
    } else {
      setT(".property-type", auction.type || "Sin tipo");
      setT(".property-address", auction.propertyAddress || "Sin dirección");
      setT(".location-text", `${auction.city || ''}, ${auction.province || ''}`.replace(', ', '').trim() || "No disponible");
    }

    // rellenar info económica
    setT(".auction-value", auction.auctionValue);
    setT(".deposit-amount", auction.depositAmount);
    setT(".appraisal", auction.appraisal);
    setT(".minimum-bid", auction.minimumBid);
    setT(".bid-increments", auction.bidIncrements);
    setT(".claimed-amount", auction.claimedAmount);

    // descripción y ubicación
    setT(".goods-description", auction.goodsDescription);
    setT(".cadastral-reference", auction.cadastralReference);
    setT(".postal-code", auction.postalCode);
    setT(".province-text", auction.province);
    setT(".city-text", auction.city);
    setT(".cru-text", auction.cru);
    setT(".registry-data", auction.registryData);

    // autoridad
    setT(".authority-code", auction.authorityCode);
    setT(".authority-description", auction.authorityDescription);
    setT(".authority-address", auction.authorityAddress);
    setT(".authority-phone", auction.authorityPhone);
    setT(".authority-email", auction.authorityEmail);
    setT(".authority-fax", auction.authorityFax);

    // información legal
    setT(".auction-id", auction.auctionId);
    setT(".expediente", auction.expediente);
    setT(".court-name", auction.courtName);
    setT(".boe-announcement", auction.boeAnnouncement);
    setT(".date-start", auction.dateOfStart);
    setT(".date-end", auction.dateOfEnd);
    setT(".is-habitual-residence", auction.isHabitualResidence);
    setT(".is-visitable", auction.isVisitable);
    setT(".possession-status", auction.possessionStatus);
    setT(".has-bids", auction.hasBids ? "Sí" : "No");

    // acreedor
    setT(".creditor-name", auction.creditorName);
    setT(".creditor-nif", auction.creditorNif);
    setT(".creditor-address", auction.creditorAddress);

    // barra lateral
    setT(".detail-status", auction.status);
    setT(".sidebar-auction-value", auction.auctionValue);
    setT(".sidebar-has-bids", auction.hasBids ? "Sí" : "No");
    setT(".lots-number", auction.lotsNumber);
    setT(".counting-account", auction.countingAccount);

    // extraer y mostrar resúmenes de IA
    const aiSummaries = [];
    if (auction.documents && auction.documents.length > 0) {
      auction.documents.forEach((doc) => {
        if (doc.docAiAnalysis) aiSummaries.push({ summary: doc.docAiAnalysis, title: doc.documentTitle || "Documento General" });
      });
    }
    if (auction.lots && auction.lots.length > 0) {
      auction.lots.forEach((lot) => {
        if (lot.documents && lot.documents.length > 0) {
           lot.documents.forEach((doc) => {
             if (doc.docAiAnalysis) aiSummaries.push({ summary: doc.docAiAnalysis, title: doc.documentTitle || `Documento Lote ${lot.lotId}` });
           });
        }
      });
    }

    const aiDocsSection = document.getElementById("ai-docs-summary-section");
    const aiSummariesList = document.getElementById("ai-summaries-list");
    if (aiSummaries.length > 0 && aiDocsSection && aiSummariesList) {
      aiDocsSection.classList.remove("hidden");
      aiSummariesList.innerHTML = aiSummaries.map(item => 
        `<div style="font-size: 0.9rem; color: var(--color-text-main); line-height: 1.5; background: white; padding: 0.75rem; border-radius: 0.5rem; box-shadow: var(--shadow-sm);"><strong style="display:block; margin-bottom: 0.25rem; font-size: 0.8rem; color: var(--color-primary);">${item.title}</strong>${markdownToHtml(item.summary)}</div>`
      ).join('');
    } else if (aiDocsSection) {
      aiDocsSection.classList.add("hidden");
    }

    // documentos (a nivel de subasta)
    const docsSection = document.getElementById("docs-section");
    const docsList = document.getElementById("docs-list");
    
    if (docsSection && docsList) {
      if (auction.documents && auction.documents.length > 0) {
        docsSection.classList.remove("hidden");
        docsList.innerHTML = "";
        auction.documents.forEach((doc) => {
          const li = document.createElement("li");
          li.innerHTML = `<a href="${doc.documentUrl}" target="_blank" class="doc-link">
            <span class="doc-icon"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg></span> Ver documento adjunto
          </a>
          ${doc.docAiAnalysis ? `<div class="doc-ai-analysis" style="font-size: 0.85rem; margin-top: 0.5rem; color: var(--color-text-muted); background: #f8fafc; padding: 0.5rem; border-radius: 0.5rem; border-left: 3px solid var(--color-accent);">${markdownToHtml(doc.docAiAnalysis)}</div>` : ''}`;
          docsList.appendChild(li);
        });
      } else {
        docsSection.classList.add("hidden");
      }
    }

    // Lotes
    const lotsSection = document.getElementById("lots-section");
    const lotsContainer = document.getElementById("lots-container");
    const lotsCountEl = document.getElementById("lots-count");
    
    // secciones que se ocultan para multilote
    const econSection = document.getElementById("econ-section");
    const descSection = document.getElementById("desc-section");
    const locSection = document.getElementById("loc-section");

    // Determinar si es multilote usando el número de lotes del campo o la longitud del array
    const lotsCount = parseInt(auction.lotsNumber) || (auction.lots ? auction.lots.length : 0);
    const hasLots = lotsCount > 0;
    const isMultiLotByCount = lotsCount > 1;

    if (hasLots) {
      lotsSection.classList.remove("hidden");
      lotsCountEl.textContent = lotsCount.toString();
      lotsContainer.innerHTML = "";

      // Ocultar secciones redundantes SOLO si es multilote (varios lotes)
      if (isMultiLotByCount) {
        econSection?.classList.add("hidden");
        descSection?.classList.add("hidden");
        locSection?.classList.add("hidden");
      } else {
        econSection?.classList.remove("hidden");
        descSection?.classList.remove("hidden");
        locSection?.classList.remove("hidden");
      }

      auction.lots.forEach((lot, index) => {
        const accordionItem = document.createElement("div");
        accordionItem.className = "accordion-item";
        
        accordionItem.innerHTML = `
          <button class="accordion-header" type="button">
            <span class="accordion-title">
              <strong>Lote ${index + 1}:</strong> ${lot.lotTitle || "Sin título"}
            </span>
            <span class="accordion-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </span>

          </button>
          <div class="accordion-content">
            <div class="accordion-content-inner">
              <div class="lot-data-grid">
                <div class="data-item">
                  <span class="label">ID Lote:</span>
                  <span class="value">${lot.lotId}</span>
                </div>
                <div class="data-item">
                  <span class="label">Valor Subasta:</span>
                  <span class="value">${lot.auctionValue || "N/D"}</span>
                </div>
                <div class="data-item">
                  <span class="label">Depósito:</span>
                  <span class="value">${lot.depositAmount || "N/D"}</span>
                </div>
                <div class="data-item">
                  <span class="label">Puja Mínima:</span>
                  <span class="value">${lot.bidSteps || "N/D"}</span>
                </div>
                <div class="data-item full-width">
                  <span class="label">Referencia Catastral:</span>
                  <span class="value">${lot.cadastralReference || "No disponible"}</span>
                </div>
                <div class="data-item full-width">
                  <span class="label">Ubicación:</span>
                  <span class="value">${lot.propertyAddress || ""}, ${lot.city || ""} (${lot.province || ""})</span>
                </div>
                <div class="data-item full-width">
                  <span class="label">Descripción:</span>
                  <p class="value goods-description">${lot.goodsDescription || "Sin descripción"}</p>
                </div>
                ${lot.documents && lot.documents.length > 0 ? `
                  <div class="data-item full-width mt-2">
                    <span class="label">Documentos del Lote:</span>
                    <ul class="lot-docs-list">
                      ${lot.documents.map(doc => `
                        <li>
                          <a href="${doc.documentUrl}" target="_blank" class="doc-link">
                            <span class="doc-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg></span> Ver documento del lote
                          </a>
                        </li>
                      `).join('')}
                    </ul>
                  </div>
                ` : ''}
              </div>
            </div>
          </div>
        `;

        const header = accordionItem.querySelector(".accordion-header");
        header?.addEventListener("click", () => {
          const isOpen = accordionItem.classList.contains("active");
          
          // si se abre uno cerrar todos los demas
          const allItems = lotsContainer.querySelectorAll('.accordion-item');
          allItems.forEach(item => {
            item.classList.remove('active');
          });
          
          // Si no estaba abierto, lo abrimos. Si lo estaba, se queda cerrado (por el remove anterior).
          if (!isOpen) {
            accordionItem.classList.add("active");
          }
        });

        lotsContainer.appendChild(accordionItem);
      });
      
      // Abrir el primero por defecto
      if (auction.lots.length > 0) {
        lotsContainer.querySelector(".accordion-item")?.classList.add("active");
      }
    } else {
      lotsSection.classList.add("hidden");
      econSection?.classList.remove("hidden");
      descSection?.classList.remove("hidden");
      locSection?.classList.remove("hidden");
    }
  });

  // Restaurar estado de búsqueda en el botón de retorno (si existe en el DOM)
  if (typeof window !== 'undefined') {
    const savedSearch = sessionStorage.getItem('last_auction_search');
    if (savedSearch) {
      const backBtn = document.getElementById('back-to-list-bottom') as HTMLAnchorElement;
      if (backBtn) {
        backBtn.href = `/auctionsList${savedSearch}`;
      }
