---
/**
 * Componente de estado de error reutilizable
 */
interface Props {
  message?: string;
  id?: string;
  messageId?: string;
  hidden?: boolean;
}

const {
  message = "Ha ocurrido un error al obtener los datos.",
  id = "error-view",
  messageId = "error-message",
  hidden = true
} = Astro.props;
---

<div id={id} class={`error-container ${hidden ? 'hidden' : ''}`}>
  <div class="error-icon">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
  </div>

  <p id={messageId}>{message}</p>
  <button onclick="window.location.reload()" class="btn-primary">Reintentar</button>
</div>

<style>
  .error-container {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--color-bg-card);
    border-radius: 1rem;
    border: 1px solid var(--border-color);
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .error-container p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .error-icon {
    font-size: 3rem;
  }

  .hidden {
    display: none;
  }
</style>
