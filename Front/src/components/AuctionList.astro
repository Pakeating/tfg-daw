---
/**
 * Lista de subastas
 * Recibe el evento de búsqueda y renderiza las tarjetas de subasta.
 */
import LoadingState from './LoadingState.astro';
import ErrorState from './ErrorState.astro';
import AuctionListLots from './AuctionListLots.astro';
---

<AuctionListLots />

<div id="auction-results-wrapper">
	
  <LoadingState id="loading-view" hidden={false} />
  <ErrorState id="error-view" />

  <div id="auction-results-container" class="auction-list hidden">
    <!-- cards -->
  </div>

  <div id="no-results-view" class="no-results hidden">
    <p>No se encontraron subastas que coincidan con tus criterios.</p>
    <a href="/auctions" class="btn-accent">Volver al Buscador</a>
  </div>
</div>

<!-- Plantilla para card de subasta -->
<template id="auction-card-template">
  <div class="card auction-card">
    <div class="card-header">
      <span class="property-type"></span>
      <div class="status-badge" data-status=""></div>
    </div>
    <div class="auction-content">
      <h3 class="property-address"></h3>
      <p class="location">
        <span class="icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </span> 
        <span class="location-text"></span>
      </p>

      
      <auction-list-lots class="hidden"></auction-list-lots>
      
      <div class="auction-details">
        <div class="detail">
          <span class="label">Valor Subasta</span>
          <span class="value auction-value"></span>
        </div>
        <div class="detail">
          <span class="label">Depósito (5%)</span>
          <span class="value deposit-amount"></span>
        </div>
      </div>
      
      <a href="" class="btn-primary block detail-link" style="margin-top: auto;">Ver Detalles</a>
    </div>
  </div>
</template>

<script>
  const container = document.getElementById('auction-results-container');
  const loadingView = document.getElementById('loading-view');
  const errorView = document.getElementById('error-view');
  const errorMessage = document.getElementById('error-message');
  const noResultsView = document.getElementById('no-results-view');
  // @ts-ignore
  const template = document.getElementById('auction-card-template');

  // Función para resetear vistas
  const resetViews = () => {
    container.classList.add('hidden');
    loadingView.classList.add('hidden');
    errorView.classList.add('hidden');
    noResultsView.classList.add('hidden');
  };

  // Escuchar cuando la carga comienza
  document.addEventListener('auctions:loading', () => {
    resetViews();
    loadingView.classList.remove('hidden');
  });

  // Escuchar cuando ocurre un error
  document.addEventListener('auctions:error', (event) => {
    resetViews();
    // @ts-ignore
    errorMessage.textContent = event.detail.message || 'Ha ocurrido un error al obtener los datos.';
    errorView.classList.remove('hidden');
  });

  // Escuchar el evento cuando se obtienen nuevas subastas
  document.addEventListener('auctions:fetched', (event) => {
    // @ts-ignore
    const { results } = event.detail;
    
    resetViews();

    if (results.length === 0) {
      noResultsView.classList.remove('hidden');
      return;
    }

    // Limpiar resultados anteriores
    container.innerHTML = '';
    container.classList.remove('hidden');

    results.forEach(auction => {
      // @ts-ignore
      const templateContent = template.content;
      const clone = templateContent.cloneNode(true);
      
      const badge = clone.querySelector('.status-badge');
      badge.textContent = auction.status;
      badge.dataset.status = auction.status;
      
      // Determinar si es multilote usando el número de lotes del campo o la longitud del array
      const lotsCount = parseInt(auction.lotsNumber) || (auction.lots ? auction.lots.length : 0);
      const isMultiLot = lotsCount > 1;
      
      if (isMultiLot) {
        clone.querySelector('.property-type').textContent = 'Multilote';
        clone.querySelector('.property-address').textContent = 'Subasta Multilote';
        clone.querySelector('.location-text').textContent = 'No disponible';
      } else {
        clone.querySelector('.property-type').textContent = auction.type || 'Sin tipo';
        clone.querySelector('.property-address').textContent = auction.propertyAddress || 'Sin dirección';
        clone.querySelector('.location-text').textContent = `${auction.city || ''}, ${auction.province || ''}`.replace(', ', '').trim() || 'No disponible';
      }
      
      clone.querySelector('.auction-value').textContent = auction.auctionValue;
      clone.querySelector('.deposit-amount').textContent = auction.depositAmount;
      
      // Manejo de lotes
      const lotsComponent = clone.querySelector('auction-list-lots');
      const auctionDetails = clone.querySelector('.auction-details');
      
      if (lotsComponent) {
        // @ts-ignore
        lotsComponent.lots = auction.lots;
      }

      if (isMultiLot && auctionDetails) {
        auctionDetails.classList.add('hidden');
      }

      clone.querySelector('.detail-link').href = `/auctionDetails?auctionIds=${auction.auctionId}`;
      
      container.appendChild(clone);
    });
  });
</script>

<style>
	.auction-list {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 2.5rem;
	}
	.auction-card {
		padding: 0;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		position: relative;
    height: 100%;
    border-top: 4px solid var(--color-primary);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
	}
  .auction-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .card-header {
    padding: 1.5rem 1.5rem 0.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
	.status-badge {
    position: static;
		padding: 0.25rem 0.75rem;
		border-radius: 2rem;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	.status-badge[data-status="En curso"] {
		background-color: #22c55e;
		color: white;
	}
	.status-badge[data-status="Próximamente"] {
		background-color: #f59e0b;
		color: white;
	}
	.status-badge[data-status="Finalizada"] {
		background-color: #ef4444;
		color: white;
	}
	.property-type {
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--color-accent);
		text-transform: uppercase;
	}
	.auction-content {
		padding: 0 1.5rem 1.5rem 1.5rem;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}
	h3 {
		margin-bottom: 0.5rem;
		font-size: 1.25rem;
	}
	.location {
		color: var(--color-text-muted);
		font-size: 0.9rem;
		margin-bottom: 1.5rem;
	}
	.auction-details {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-bottom: 1.5rem;
		padding: 1rem 0;
		border-top: 1px solid var(--border-color);
		border-bottom: 1px solid var(--border-color);
	}
	.detail {
		display: flex;
		flex-direction: column;
	}
	.label {
		font-size: 0.75rem;
		text-transform: uppercase;
		color: var(--color-text-muted);
		letter-spacing: 0.05em;
		margin-bottom: 0.25rem;
	}
	.value {
		font-weight: 700;
		color: var(--color-primary);
	}
	.block {
		display: block;
		text-align: center;
		width: 100%;
	}
  .no-results {
		text-align: center;
		padding: 4rem 2rem;
		background: var(--color-bg-card);
		border-radius: 1rem;
		border: 1px dashed var(--border-color);
		margin-top: 2rem;
	}
	.no-results p {
		font-size: 1.25rem;
		color: var(--color-text-muted);
		margin-bottom: 2rem;
	}
	.hidden {
		display: none;
	}

  .page-info .total {
    color: var(--color-text-muted);
  }

  .btn-pagination .icon {
    font-size: 1.1rem;
    transition: transform 0.2s;
  }

  .btn-pagination:hover:not(:disabled) .icon {
    transform: scale(1.2);
  }
</style>
