---
/**
 * Componente de estado de carga reutilizable
 */
interface Props {
  message?: string;
  id?: string;
  hidden?: boolean;
}

const { 
  message = "Obteniendo datos...", 
  id = "loading-view",
  hidden = true 
} = Astro.props;
---

<div id={id} class={`loading-container ${hidden ? 'hidden' : ''}`}>
  <div class="spinner"></div>
  <p>{message}</p>
</div>

<style>
  .loading-container {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--color-bg-card);
    border-radius: 1rem;
    border: 1px solid var(--border-color);
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .loading-container p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .spinner {
    width: 50px;
    height: 50px;
    border: 4px solid var(--border-color);
    border-left-color: var(--color-accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .hidden {
    display: none;
  }
</style>
