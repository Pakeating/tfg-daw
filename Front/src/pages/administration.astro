---
/**
 * Panel de Administración - Solo para administradores
 */
import Layout from "../layouts/Layout.astro";

const user = Astro.locals.user;

if (!user || user.role !== 'admin') {
  return Astro.redirect("/login");
}
---

<Layout title="Administración — InmoPaco">
  <main class="admin-container">
    <div class="admin-header">
      <div class="header-content">
        <h1>Panel de Administración</h1>
        <p>Bienvenido, {user.name || user.email}. Aquí podrás gestionar los datos internos y la IA.</p>
      </div>
      <div class="header-badge">
        <span class="role-badge">ADMIN</span>
      </div>
    </div>

    <!-- Sidebar colapsable de acciones -->
    <aside id="sidebar" class="sidebar" aria-label="Panel de acciones">
      <div class="sidebar-content">
        <div class="sidebar-header">
          <h3>Acciones Backend</h3>
          <button id="sidebar-close" class="sidebar-close" aria-label="Cerrar sidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <nav class="sidebar-actions">
          <button type="button" id="btn-purge" class="btn-backend-action">Purgado de Colas</button>
          <button type="button" id="btn-delete-consumer" class="btn-backend-action">Eliminar Consumidor</button>
          <button type="button" id="btn-scheduler" class="btn-backend-action">Lanzar AuctionScheduler</button>
          <button type="button" id="btn-property-scheduler" class="btn-backend-action">Lanzar PropertyScheduler</button>
          <button type="button" id="btn-get-auctions" class="btn-backend-action">Obtener Subastas</button>
          <button type="button" id="btn-process" class="btn-backend-action">Procesar Subastas</button>
          <button type="button" id="btn-province-notifications" class="btn-backend-action">Notificaciones por Provincia</button>
        </nav>
      </div>
    </aside>

    <!-- Botón toggle flotante -->
    <button id="sidebar-toggle" class="sidebar-toggle" aria-label="Abrir panel de acciones" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20">
        <path d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <span>Acciones</span>
    </button>

    <div class="admin-layout">
      <!-- Columna Izquierda: Boton Admin -->
      <div class="admin-left-col">
        <section class="backend-admin-section">
          <div class="backend-admin-content">
            <a href="/admin/" target="_blank" rel="noopener noreferrer" class="btn-backend-admin">BackEnd Admin</a>
          <a href="/portainer/" target="_blank" rel="noopener noreferrer" class="btn-backend-admin">Backend Portainer</a>
          <a href="/bff/swagger-ui/index.html" target="_blank" rel="noopener noreferrer" class="btn-backend-admin">BFF Swagger</a>
          <a href="/adminer/" target="_blank" rel="noopener noreferrer" class="btn-backend-admin">Adminer</a>
          </div>
        </section>
      </div>

      <!-- Columna Derecha: Cards de Estado/Configuracion -->
      <div class="admin-right-col">
        <div class="admin-grid-column">
          <!-- Card: Estadisticas rapidas -->
          <div class="admin-card stats-card">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                <path d="M3 3v18h18M18 9l-6 6-4-4-5 5" />
              </svg>
            </div>
            <div class="card-body">
              <h3>Sistema Operativo</h3>
              <p class="status">Conectado al Backend Java</p>
              <div class="progress-bar"><div class="progress" style="width: 85%"></div></div>
            </div>
          </div>

          <!-- Card: Gestion de Usuarios -->
          <div class="admin-card action-card">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
            </div>
            <div class="card-body">
              <h3>Control de Usuarios</h3>
              <p>Gestiona privilegios y accesos a la plataforma.</p>
              <button class="btn-secondary" disabled>Próximamente</button>
            </div>
          </div>

          <!-- Card: Configuracion de la IA -->
          <div class="admin-card action-card">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                <path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
              </svg>
            </div>
            <div class="card-body">
              <h3>Modelos de IA</h3>
              <p>Ajusta los prompts y modelos para resúmenes automáticos.</p>
              <button class="btn-secondary" disabled>Próximamente</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Toast-->
    <div id="toast" class="toast" role="alert" aria-live="polite"></div>

    <!-- Modal: Delete Consumer -->
    <div id="modal-delete-consumer" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-dc-title" style="display:none">
      <div class="modal-box">
        <h2 id="modal-dc-title">Delete Consumer</h2>
        <p class="modal-desc">Introduce los parámetros para eliminar el consumer de la cola.</p>
        <form id="form-delete-consumer" novalidate>
          <label for="dc-stream">Stream</label>
          <input type="text" id="dc-stream" name="stream" value="AUCTIONS_STREAM" required />
          <label for="dc-subject">Subject</label>
          <input type="text" id="dc-subject" name="subject" value="auctions.response" required />
          <div class="modal-actions">
            <button type="button" class="btn-modal-cancel" id="cancel-dc">Cancelar</button>
            <button type="submit" class="btn-modal-confirm btn-danger">Confirmar y Enviar</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal: Get Auctions -->
    <div id="modal-get-auctions" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-ga-title" style="display:none">
      <div class="modal-box">
        <h2 id="modal-ga-title">Get Auctions</h2>
        <p class="modal-desc">Introduce el payload de subastas a obtener.</p>
        <form id="form-get-auctions" novalidate>
          <label for="ga-payload">Auctions Payload (número)</label>
          <input type="number" id="ga-payload" name="auctionsPayload" value="47" min="1" required />
          <div class="modal-actions">
            <button type="button" class="btn-modal-cancel" id="cancel-ga">Cancelar</button>
            <button type="submit" class="btn-modal-confirm">Confirmar y Enviar</button>
          </div>
        </form>
      </div>
    </div>
  </main>
</Layout>

<style>
  .admin-container {
    max-width: 1000px;
    margin: 3rem auto;
    padding: 0 1.5rem;
  }

  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3rem;
  }

  .admin-header h1 {
    font-size: 2.25rem;
    font-weight: 800;
    color: #0a2540;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .admin-header p {
    color: #64748b;
    font-size: 1.125rem;
  }

  .role-badge {
    background: #0a2540;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 2rem;
    letter-spacing: 0.05em;
  }

  .admin-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .admin-layout {
      grid-template-columns: 1fr;
    }
  }

  .admin-grid-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .admin-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    gap: 1.25rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .admin-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px -8px rgba(0,0,0,0.1);
  }

  .card-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    background: #f8fafc;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #f97316;
    flex-shrink: 0;
  }

  .card-body h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: #0f172a;
  }

  .card-body p {
    font-size: 0.875rem;
    color: #64748b;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .status {
    font-weight: 600;
    color: #10b981 !important;
  }

  .progress-bar {
    height: 6px;
    background: #f1f5f9;
    border-radius: 3px;
    overflow: hidden;
  }

  .progress {
    height: 100%;
    background: #10b981;
  }

  .btn-secondary {
    padding: 0.5rem 1rem;
    background: #f1f5f9;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #94a3b8;
    cursor: not-allowed;
  }

  .backend-admin-section {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 1.5rem;
    padding: 3rem 2rem;
    display: flex;
    justify-content: center;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
  }

  .backend-admin-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    max-width: 400px;
    width: 100%;
  }

  .btn-backend-admin {
    background: #f97316;
    color: white;
    border: none;
    border-radius: 0.75rem;
    padding: 1.25rem 2.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    width: 100%;
    box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3);
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .btn-backend-admin + .btn-backend-admin {
    margin-top: 1rem;
  }

  .btn-backend-admin:hover {
    background: #ea580c;
    transform: translateY(-2px);
  }

  .action-column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }

  .btn-backend-action {
    background: #fff;
    border: 1.5px solid #f97316;
    color: #f97316;
    border-radius: 0.5rem;
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
  }

  .btn-backend-action:hover {
    background: #fff7ed;
    border-color: #ea580c;
    color: #ea580c;
  }

  .btn-icon {
    font-size: 0.9rem;
    margin-right: 0.25rem;
  }

  /* Modales */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10, 37, 64, 0.55);
    backdrop-filter: blur(3px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .modal-overlay.open {
    display: flex;
  }

  .modal-box {
    background: #fff;
    border-radius: 1rem;
    padding: 2rem;
    width: min(420px, 90vw);
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    animation: slideUp 0.2s ease;
  }

  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .modal-box h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0a2540;
    margin-bottom: 0.5rem;
  }

  .modal-desc {
    font-size: 0.875rem;
    color: #64748b;
    margin-bottom: 1.25rem;
  }

  .modal-box label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: #475569;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .modal-box input {
    width: 100%;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 0.625rem 0.875rem;
    font-size: 0.9rem;
    color: #0f172a;
    margin-bottom: 1rem;
    box-sizing: border-box;
    transition: border-color 0.15s;
  }

  .modal-box input:focus {
    outline: none;
    border-color: #0a2540;
  }

  .modal-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }

  .btn-modal-cancel {
    padding: 0.625rem 1.25rem;
    background: #f1f5f9;
    border: none;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.875rem;
    color: #64748b;
    cursor: pointer;
  }

  .btn-modal-confirm {
    padding: 0.625rem 1.25rem;
    background: #0a2540;
    border: none;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.875rem;
    color: #fff;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-modal-confirm.btn-danger { background: #dc2626; }
  .btn-modal-confirm:hover { opacity: 0.9; }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: #0a2540;
    color: #fff;
    padding: 1rem 1.5rem;
    border-radius: 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px);
    transition: opacity 0.3s, transform 0.3s;
    z-index: 2000;
    max-width: 360px;
  }

  .toast.show {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .toast.error { background: #dc2626; }
  .toast.success { background: #059669; }

  /* Sidebar */
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: 280px;
    background: #fff;
    border-right: 1px solid #e2e8f0;
    box-shadow: 4px 0 24px rgba(0,0,0,0.1);
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 100;
    display: flex;
    flex-direction: column;
  }

  .sidebar.open {
    transform: translateX(0);
  }

  .sidebar-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #e2e8f0;
    background: #0a2540;
  }

  .sidebar-header h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .sidebar-close {
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.7);
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .sidebar-close:hover {
    color: #fff;
  }

  .sidebar-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    overflow-y: auto;
  }

  .sidebar-toggle {
    position: fixed;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    background: #0a2540;
    color: #fff;
    border: none;
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 1rem 0.75rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.7rem;
    font-weight: 600;
    box-shadow: 2px 4px 12px rgba(0,0,0,0.15);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 99;
  }

  .sidebar-toggle:hover {
    background: #0f3460;
    left: 2px;
  }

  .sidebar-toggle svg {
    display: block;
  }

  .sidebar-toggle span {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    letter-spacing: 0.05em;
  }

  .sidebar.open + .sidebar-toggle {
    left: 280px;
    border-radius: 0 0.5rem 0.5rem 0;
  }

  /* Overlay cuando sidebar abierto */
  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 37, 64, 0.4);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
    z-index: 50;
  }

  .sidebar-overlay.visible {
    opacity: 1;
    visibility: visible;
  }
</style>

<script>
  // Modal
  function openModal(id) {
    const el = document.getElementById(id);
    if (el) el.style.display = 'flex';
  }

  function closeModal(id) {
    const el = document.getElementById(id);
    if (el) el.style.display = 'none';
  }

  // Toast
  let toastTimer;
  function showToast(msg, type = 'success') {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = msg;
    toast.className = `toast ${type} show`;
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 5000);
  }

  // llama al orquestrador con timeout de 30s
  async function callOrchestrator(action, params = {}) {
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 30000);

    try {
      const res = await fetch('/api/orchestrator', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, ...params }),
        signal: controller.signal
      });
      clearTimeout(timeout);

      const data = await res.json();
      if (res.ok && data.success) {
        showToast(` ${action}: completado (HTTP ${data.status})`, 'success');
      } else {
        const msg = data.error ?? data.data?.message ?? `Error ${res.status}`;
        showToast(` ${action}: ${msg}`, 'error');
      }
    } catch (err) {
      clearTimeout(timeout);
      if (err.name === 'AbortError') {
        showToast(` ${action}: tiempo de espera agotado (30s)`, 'error');
      } else {
        showToast(` Error de conexión: ${err.message}`, 'error');
      }
    }
  }

  // Purge Queue
  document.getElementById('btn-purge')?.addEventListener('click', () => {
    if (!confirm('¿Seguro que quieres purgar la cola? Esta acción no se puede deshacer.')) return;
    callOrchestrator('purge');
  });

  // Delete Consumer
  document.getElementById('btn-delete-consumer')?.addEventListener('click', () => {
    openModal('modal-delete-consumer');
  });
  document.getElementById('cancel-dc')?.addEventListener('click', () => {
    closeModal('modal-delete-consumer');
  });
  document.getElementById('form-delete-consumer')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const stream = (document.getElementById('dc-stream') as HTMLInputElement).value.trim();
    const subject = (document.getElementById('dc-subject') as HTMLInputElement).value.trim();
    if (!stream || !subject) { showToast('Completa todos los campos', 'error'); return; }
    closeModal('modal-delete-consumer');
    callOrchestrator('deleteConsumer', { stream, subject });
  });

  // AuctionScheduler
  document.getElementById('btn-scheduler')?.addEventListener('click', () => {
    if (!confirm('¿Lanzar el AuctionScheduler ahora?')) return;
    callOrchestrator('scheduler');
  });

  // PropertyScheduler
  document.getElementById('btn-property-scheduler')?.addEventListener('click', () => {
    if (!confirm('¿Lanzar el PropertyScheduler ahora?')) return;
    callOrchestrator('propertyScheduler');
  });

  // Get Auctions
  document.getElementById('btn-get-auctions')?.addEventListener('click', () => {
    openModal('modal-get-auctions');
  });
  document.getElementById('cancel-ga')?.addEventListener('click', () => {
    closeModal('modal-get-auctions');
  });
  document.getElementById('form-get-auctions')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const auctionsPayload = (document.getElementById('ga-payload') as HTMLInputElement).value.trim();
    if (!auctionsPayload) { showToast('Introduce un payload válido', 'error'); return; }
    closeModal('modal-get-auctions');
    callOrchestrator('getAuctions', { auctionsPayload });
  });

  // Process Auctions
  document.getElementById('btn-process')?.addEventListener('click', () => {
    if (!confirm('¿Procesar subastas ahora? (auctionsPayload vacío)')) return;
    callOrchestrator('processAuctions');
  });

  // Province Notifications
  document.getElementById('btn-province-notifications')?.addEventListener('click', () => {
    if (!confirm('¿Enviar notificaciones de subastas por provincia?')) return;
    callOrchestrator('provinceNotifications');
  });

// Cerrar modales al clicar fuera
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    const el = overlay as HTMLElement; 
    el.addEventListener('click', (e) => {
      if (e.target === el) {
        el.style.display = 'none';
      }
    });
  });

  // Sidebar toggle
  const sidebar = document.getElementById('sidebar');
  const sidebarToggle = document.getElementById('sidebar-toggle');
  const sidebarClose = document.getElementById('sidebar-close');

  sidebarToggle?.addEventListener('click', () => {
    sidebar?.classList.add('open');
    sidebarToggle.setAttribute('aria-expanded', 'true');
  });

  sidebarClose?.addEventListener('click', () => {
    sidebar?.classList.remove('open');
    sidebarToggle?.setAttribute('aria-expanded', 'false');
  });

  // Cerrar sidebar al hacer click fuera (en overlay)
  document.addEventListener('click', (e) => {
    if (sidebar?.classList.contains('open') && 
        !sidebar.contains(e.target as Node) && 
        !sidebarToggle?.contains(e.target as Node)) {
      sidebar.classList.remove('open');
      sidebarToggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
